{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
       "config": { "nodejs": "20.x" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
         "nodejs": "20.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/api-docs(.*)",
      "dest": "api/index.js"
    }
    ,{ "src": "/(.*)", "dest": "/frontend/dist/$1" }
  ]
}